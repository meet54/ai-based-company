# === FREE AI (recommended) ===
# Groq — free, fast, no credit card: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — free tier: https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# === PAID AI ===
# OpenAI — requires billing: https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CEO account details
CEO_NAME=Your Name
CEO_EMAIL=ceo@yourcompany.com
COMPANY_NAME=AI Nexus Solutions

# Server
HOST=0.0.0.0
PORT=8765

# demo = simulated AI | groq/gemini/openai = real AI
DEMO_MODE=false

# Set to false only if you get SSL certificate errors on Windows
SSL_VERIFY=false
